<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prolub SST - Dashboard Profesional</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        prolub: {
                            purple: '#5B0599',
                            red: '#F5014D',
                            grey: '#D9D4D4',
                            lavender: '#E4C2FF',
                            midpurple: '#8D5DAC',
                            yellow: '#FAD000'
                        }
                    }
                }
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .transition-content { transition: opacity 0.2s ease-in-out; }
        .active-link { border-left: 4px solid #F5014D; background-color: #f8f4ff; color: #5B0599 !important; }
    </style>
</head>
<body class="bg-white text-slate-900">

    <!-- PANTALLA DE LOGIN -->
    <div id="login-view" class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
        <div class="max-w-md w-full bg-white p-10 rounded-3xl shadow-2xl border border-gray-100">
            <div class="flex flex-col items-center mb-8">
                <!-- Logo Simulado Prolub -->
                <div class="flex items-center space-x-1 mb-2">
                    <span class="text-4xl font-extrabold text-prolub-purple">Pro</span>
                    <div class="w-10 h-10 relative">
                        <svg viewBox="0 0 100 100" class="w-full h-full"><path d="M10 90L50 10L90 65L10 90Z" fill="#F5014D"/></svg>
                    </div>
                    <span class="text-4xl font-extrabold text-prolub-purple">lub</span>
                </div>
                <p class="text-gray-400 font-medium uppercase tracking-widest text-xs">Gestión Integral SST</p>
            </div>
            
            <form id="loginForm" class="space-y-5">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Usuario</label>
                    <input type="text" id="username" placeholder="admin" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-prolub-purple focus:border-transparent outline-none transition-all">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Contraseña</label>
                    <input type="password" id="password" placeholder="••••" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-prolub-purple focus:border-transparent outline-none transition-all">
                </div>
                <div id="loginError" class="hidden text-prolub-red text-xs font-bold text-center">Credenciales incorrectas. Intenta con admin / 1234</div>
                <button type="submit" class="w-full bg-prolub-purple text-white font-bold py-4 rounded-xl hover:bg-opacity-90 transform transition active:scale-95 shadow-lg shadow-purple-200">
                    Ingresar al Sistema
                </button>
            </form>
        </div>
    </div>

    <!-- ESTRUCTURA PRINCIPAL (HIDDEN BY DEFAULT) -->
    <div id="main-view" class="hidden min-h-screen flex bg-white">
        
        <!-- Sidebar -->
        <aside class="w-72 border-r border-prolub-grey flex flex-col h-screen sticky top-0 bg-white z-50">
            <div class="p-8 flex items-center space-x-2">
                <span class="text-2xl font-black text-prolub-purple">Pro</span>
                <div class="w-6 h-6"><svg viewBox="0 0 100 100"><path d="M10 90L50 10L90 65L10 90Z" fill="#F5014D"/></svg></div>
                <span class="text-2xl font-black text-prolub-purple">lub</span>
            </div>

            <nav class="flex-1 px-4 py-4 space-y-2">
                <button onclick="navigate('inicio')" id="btn-inicio" class="nav-link active-link w-full flex items-center px-6 py-4 text-gray-500 font-semibold rounded-xl transition-all">
                    <i data-lucide="layout-grid" class="w-5 h-5 mr-4"></i> Inicio
                </button>
                <button onclick="navigate('matriz')" id="btn-matriz" class="nav-link w-full flex items-center px-6 py-4 text-gray-500 font-semibold rounded-xl transition-all hover:bg-gray-50">
                    <i data-lucide="shield-check" class="w-5 h-5 mr-4"></i> Matriz de Riesgos
                </button>
                <button onclick="navigate('reportes')" id="btn-reportes" class="nav-link w-full flex items-center px-6 py-4 text-gray-500 font-semibold rounded-xl transition-all hover:bg-gray-50">
                    <i data-lucide="bar-chart-3" class="w-5 h-5 mr-4"></i> Reportes
                </button>
                <button onclick="navigate('docs')" id="btn-docs" class="nav-link w-full flex items-center px-6 py-4 text-gray-500 font-semibold rounded-xl transition-all hover:bg-gray-50">
                    <i data-lucide="folder-kanban" class="w-5 h-5 mr-4"></i> Documentación
                </button>
            </nav>

            <div class="p-6 border-t border-prolub-grey">
                <button onclick="logout()" class="w-full flex items-center justify-center space-x-2 py-3 border-2 border-prolub-red text-prolub-red rounded-xl font-bold hover:bg-prolub-red hover:text-white transition-all">
                    <i data-lucide="log-out" class="w-4 h-4"></i>
                    <span>Cerrar Sesión</span>
                </button>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="flex-1 overflow-y-auto bg-gray-50/30">
            <!-- Header Bar -->
            <header class="bg-white border-b border-prolub-grey h-20 flex items-center justify-between px-10 sticky top-0 z-40">
                <h2 id="view-title" class="text-xl font-bold text-gray-800 uppercase tracking-tight">Dashboard General</h2>
                <div class="flex items-center space-x-6">
                    <div class="flex items-center space-x-3">
                        <div class="text-right">
                            <p class="text-sm font-bold leading-tight">Admin Prolub</p>
                            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">SST Master</p>
                        </div>
                        <div class="w-10 h-10 rounded-full bg-prolub-lavender flex items-center justify-center text-prolub-purple border-2 border-prolub-purple/10">
                            <i data-lucide="user" class="w-5 h-5"></i>
                        </div>
                    </div>
                </div>
            </header>

            <div id="content-area" class="p-10 max-w-7xl mx-auto transition-content">
                <!-- EL CONTENIDO SE INYECTA AQUÍ POR JS -->
            </div>
        </main>
    </div>

    <script>
        // Lógica de Vistas
        const views = {
            inicio: `
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
                    <div class="bg-white p-8 rounded-3xl border border-prolub-grey shadow-sm hover:shadow-xl transition-shadow border-t-4 border-t-prolub-red">
                        <p class="text-gray-400 font-bold text-xs uppercase mb-2">Accidentalidad</p>
                        <h3 class="text-4xl font-black text-prolub-purple">1.2%</h3>
                        <p class="text-green-500 text-xs font-bold mt-2">↓ 0.4% desde el mes pasado</p>
                    </div>
                    <div class="bg-white p-8 rounded-3xl border border-prolub-grey shadow-sm hover:shadow-xl transition-shadow border-t-4 border-t-prolub-purple">
                        <p class="text-gray-400 font-bold text-xs uppercase mb-2">Cumplimiento Legal</p>
                        <h3 class="text-4xl font-black text-prolub-purple">94%</h3>
                        <p class="text-prolub-midpurple text-xs font-bold mt-2">Auditado hace 5 días</p>
                    </div>
                    <div class="bg-white p-8 rounded-3xl border border-prolub-grey shadow-sm hover:shadow-xl transition-shadow border-t-4 border-t-prolub-yellow">
                        <p class="text-gray-400 font-bold text-xs uppercase mb-2">Capacitaciones</p>
                        <h3 class="text-4xl font-black text-prolub-purple">88%</h3>
                        <p class="text-orange-500 text-xs font-bold mt-2">12 sesiones pendientes</p>
                    </div>
                </div>

                <div class="bg-white p-8 rounded-3xl border border-prolub-grey shadow-sm">
                    <div class="flex justify-between items-center mb-8">
                        <div>
                            <h4 class="text-lg font-bold">Estado de Riesgos por Mes</h4>
                            <p class="text-sm text-gray-400">Análisis comparativo de incidentes</p>
                        </div>
                    </div>
                    <div class="h-80">
                        <canvas id="mainChart"></canvas>
                    </div>
                </div>
            `,
            matriz: `
                <div class="bg-white rounded-3xl border border-prolub-grey overflow-hidden shadow-sm">
                    <div class="p-6 border-b border-prolub-grey bg-gray-50 flex justify-between items-center">
                        <h3 class="font-bold">Identificación de Peligros y Valoración de Riesgos</h3>
                        <button class="bg-prolub-purple text-white px-4 py-2 rounded-lg text-sm font-bold">+ Nuevo Hallazgo</button>
                    </div>
                    <table class="w-full text-left">
                        <thead class="bg-gray-50 text-xs font-bold text-gray-500 uppercase tracking-widest">
                            <tr>
                                <th class="px-6 py-4">Proceso</th>
                                <th class="px-6 py-4">Peligro</th>
                                <th class="px-6 py-4">Consecuencia</th>
                                <th class="px-6 py-4 text-center">Nivel Riesgo</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-prolub-grey">
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 text-sm">Producción</td>
                                <td class="px-6 py-4 text-sm font-medium">Ruido continuo</td>
                                <td class="px-6 py-4 text-sm italic">Hipoacusia</td>
                                <td class="px-6 py-4 text-center"><span class="bg-prolub-yellow px-3 py-1 rounded-full text-[10px] font-black uppercase">Medio</span></td>
                            </tr>
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 text-sm">Almacenaje</td>
                                <td class="px-6 py-4 text-sm font-medium">Carga de materiales</td>
                                <td class="px-6 py-4 text-sm italic">Lesiones lumbares</td>
                                <td class="px-6 py-4 text-center"><span class="bg-prolub-red text-white px-3 py-1 rounded-full text-[10px] font-black uppercase">Alto</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            `,
            reportes: `
                <div class="flex items-center justify-center h-64 border-4 border-dashed border-prolub-grey rounded-3xl">
                    <div class="text-center">
                        <i data-lucide="construction" class="w-12 h-12 text-prolub-grey mx-auto mb-4"></i>
                        <h3 class="text-prolub-midpurple font-bold">Modulo de Reportes Estadísticos</h3>
                        <p class="text-gray-400 text-sm italic">Generando analítica en tiempo real...</p>
                    </div>
                </div>
            `,
            docs: `
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    ${['Políticas SST', 'Plan Emergencias', 'Fichas Seguridad', 'Formatos Inspección'].map(doc => `
                        <div class="bg-white p-6 rounded-2xl border border-prolub-grey hover:border-prolub-purple transition-all cursor-pointer group shadow-sm">
                            <i data-lucide="file-text" class="w-8 h-8 text-prolub-midpurple mb-4 group-hover:scale-110 transition-transform"></i>
                            <h4 class="font-bold text-sm text-gray-700">${doc}</h4>
                            <p class="text-[10px] text-gray-400 mt-2">Actualizado: Ene 2024</p>
                        </div>
                    `).join('')}
                </div>
            `
        };

        // Lógica de Autenticación
        document.getElementById('loginForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const user = document.getElementById('username').value;
            const pass = document.getElementById('password').value;

            if(user === 'admin' && pass === '1234') {
                document.getElementById('login-view').classList.add('hidden');
                document.getElementById('main-view').classList.remove('hidden');
                navigate('inicio');
            } else {
                document.getElementById('loginError').classList.remove('hidden');
            }
        });

        function logout() {
            document.getElementById('main-view').classList.add('hidden');
            document.getElementById('login-view').classList.remove('hidden');
            document.getElementById('loginForm').reset();
            document.getElementById('loginError').classList.add('hidden');
        }

        // Navegación SPA
        function navigate(viewId) {
            const contentArea = document.getElementById('content-area');
            const viewTitle = document.getElementById('view-title');
            
            // Animación fade out
            contentArea.style.opacity = '0';

            setTimeout(() => {
                contentArea.innerHTML = views[viewId];
                viewTitle.innerText = viewId === 'inicio' ? 'Dashboard General' : viewId.replace('_', ' ');
                
                // Actualizar estilo de menú lateral
                document.querySelectorAll('.nav-link').forEach(link => link.classList.remove('active-link'));
                document.getElementById(`btn-${viewId}`).classList.add('active-link');

                // Reinicializar iconos y gráficos
                lucide.createIcons();
                if(viewId === 'inicio') initChart();

                // Animación fade in
                contentArea.style.opacity = '1';
            }, 200);
        }

        function initChart() {
            const ctx = document.getElementById('mainChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun'],
                    datasets: [{
                        label: 'Incidentes Registrados',
                        data: [5, 2, 8, 4, 3, 1],
                        backgroundColor: '#5B0599',
                        borderRadius: 12,
                        barThickness: 30
                    }, {
                        label: 'Inspecciones Realizadas',
                        data: [15, 18, 12, 16, 20, 22],
                        backgroundColor: '#F5014D',
                        borderRadius: 12,
                        barThickness: 30
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top', labels: { font: { weight: 'bold', size: 12 } } }
                    },
                    scales: {
                        y: { grid: { display: false }, border: { display: false } },
                        x: { grid: { display: false }, border: { display: false } }
                    }
                }
            });
        }

        // Inicializar Iconos de Login
        lucide.createIcons();
    </script>
</body>
</html>
