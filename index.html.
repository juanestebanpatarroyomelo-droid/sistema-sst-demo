<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prolub - Gestión SST</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Iconos -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #ffffff; }
        .bg-prolub-purple { background-color: #5B0599; }
        .text-prolub-purple { color: #5B0599; }
        .bg-prolub-red { background-color: #F5014D; }
        .border-prolub-gray { border-color: #D9D4D4; }
        .bg-prolub-light { background-color: #E4C2FF; }
        .bg-prolub-yellow { background-color: #FAD000; }
        
        .transition-all { transition: all 0.3s ease; }
        .sidebar-item:hover { background-color: #f3f4f6; color: #5B0599; }
        .glass { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); }
    </style>
</head>
<body class="text-slate-800">

    <!-- PANTALLA DE LOGIN -->
    <div id="login-screen" class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
        <div class="max-w-md w-full space-y-8 bg-white p-10 rounded-2xl shadow-xl border border-gray-100">
            <div class="text-center">
                <!-- Simulación del Logo Prolub -->
                <div class="flex justify-center items-center mb-6">
                    <span class="text-3xl font-bold text-prolub-purple">Pro</span>
                    <div class="relative mx-1">
                        <svg width="40" height="40" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M20 80L50 20L80 55L20 80Z" fill="#F5014D"/>
                        </svg>
                    </div>
                    <span class="text-3xl font-bold text-prolub-purple">lub</span>
                </div>
                <h2 class="text-2xl font-bold text-gray-900">Sistema de Gestión SST</h2>
                <p class="mt-2 text-sm text-gray-500">Ingresa tus credenciales para continuar</p>
            </div>
            <form class="mt-8 space-y-6" onsubmit="event.preventDefault(); showDashboard();">
                <div class="rounded-md shadow-sm space-y-4">
                    <div>
                        <label for="user" class="block text-sm font-medium text-gray-700 mb-1">Usuario</label>
                        <input id="user" name="user" type="text" required class="appearance-none rounded-lg relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-400 text-gray-900 focus:outline-none focus:ring-prolub-purple focus:border-prolub-purple focus:z-10 sm:text-sm" placeholder="ejemplo@prolub.com">
                    </div>
                    <div>
                        <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Contraseña</label>
                        <input id="password" name="password" type="password" required class="appearance-none rounded-lg relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-400 text-gray-900 focus:outline-none focus:ring-prolub-purple focus:border-prolub-purple focus:z-10 sm:text-sm" placeholder="••••••••">
                    </div>
                </div>

                <div>
                    <button type="submit" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-semibold rounded-lg text-white bg-prolub-purple hover:bg-opacity-90 focus:outline-none transition-all">
                        Ingresar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- DASHBOARD PRINCIPAL (Oculto por defecto) -->
    <div id="dashboard" class="hidden min-h-screen flex bg-gray-50">
        
        <!-- Sidebar -->
        <aside class="w-64 bg-white border-r border-prolub-gray hidden md:flex flex-col">
            <div class="p-6 flex items-center space-x-2">
                <span class="text-xl font-bold text-prolub-purple">Prolub</span>
                <div class="w-6 h-6 bg-prolub-red rounded-sm" style="clip-path: polygon(0% 100%, 50% 0%, 100% 70%);"></div>
            </div>
            
            <nav class="mt-6 flex-1 px-4 space-y-2">
                <a href="#" class="sidebar-item flex items-center px-4 py-3 text-sm font-medium rounded-lg text-prolub-purple bg-prolub-light transition-all">
                    <i data-lucide="layout-dashboard" class="w-5 h-5 mr-3"></i> Dashboard
                </a>
                <a href="#" class="sidebar-item flex items-center px-4 py-3 text-sm font-medium rounded-lg text-gray-600 transition-all">
                    <i data-lucide="file-text" class="w-5 h-5 mr-3"></i> Reportes
                </a>
                <a href="#" class="sidebar-item flex items-center px-4 py-3 text-sm font-medium rounded-lg text-gray-600 transition-all">
                    <i data-lucide="shield-alert" class="w-5 h-5 mr-3"></i> Matrices de Riesgo
                </a>
                <a href="#" class="sidebar-item flex items-center px-4 py-3 text-sm font-medium rounded-lg text-gray-600 transition-all">
                    <i data-lucide="folder" class="w-5 h-5 mr-3"></i> Documentación
                </a>
                <a href="#" class="sidebar-item flex items-center px-4 py-3 text-sm font-medium rounded-lg text-gray-600 transition-all">
                    <i data-lucide="settings" class="w-5 h-5 mr-3"></i> Configuración
                </a>
            </nav>

            <div class="p-4 border-t border-gray-100">
                <button onclick="location.reload()" class="flex items-center text-sm font-medium text-red-500 hover:text-red-700">
                    <i data-lucide="log-out" class="w-4 h-4 mr-2"></i> Cerrar Sesión
                </button>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 overflow-y-auto">
            <!-- Top Header -->
            <header class="bg-white border-b border-gray-100 py-4 px-8 flex justify-between items-center">
                <h1 class="text-xl font-semibold text-gray-800">Panel de Control SST</h1>
                <div class="flex items-center space-x-4">
                    <div class="text-right hidden sm:block">
                        <p class="text-sm font-medium">Juan Pérez</p>
                        <p class="text-xs text-gray-500">Coordinador SST</p>
                    </div>
                    <div class="w-10 h-10 rounded-full bg-prolub-purple flex items-center justify-center text-white font-bold">JP</div>
                </div>
            </header>

            <!-- Dashboard Content -->
            <div class="p-8 max-w-7xl mx-auto">
                <!-- Welcome Section -->
                <div class="mb-8">
                    <h2 class="text-3xl font-bold text-gray-900">Bienvenido, Juan</h2>
                    <p class="text-gray-500">Resumen general del estado de seguridad hoy.</p>
                </div>

                <!-- KPIs -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
                    <!-- KPI 1 -->
                    <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm transition-all hover:shadow-md">
                        <div class="flex items-center justify-between mb-4">
                            <div class="p-3 bg-red-50 text-prolub-red rounded-xl">
                                <i data-lucide="activity"></i>
                            </div>
                            <span class="text-xs font-bold text-red-500 bg-red-50 px-2 py-1 rounded-full">-5% vs mes ant.</span>
                        </div>
                        <p class="text-sm text-gray-500 font-medium">Índice de Accidentalidad</p>
                        <h3 class="text-2xl font-bold mt-1">1.2%</h3>
                    </div>

                    <!-- KPI 2 -->
                    <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm transition-all hover:shadow-md">
                        <div class="flex items-center justify-between mb-4">
                            <div class="p-3 bg-purple-50 text-prolub-purple rounded-xl">
                                <i data-lucide="users"></i>
                            </div>
                            <span class="text-xs font-bold text-green-500 bg-green-50 px-2 py-1 rounded-full">85% completado</span>
                        </div>
                        <p class="text-sm text-gray-500 font-medium">Capacitaciones Pendientes</p>
                        <h3 class="text-2xl font-bold mt-1">12 Empleados</h3>
                    </div>

                    <!-- KPI 3 -->
                    <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm transition-all hover:shadow-md">
                        <div class="flex items-center justify-between mb-4">
                            <div class="p-3 bg-yellow-50 text-prolub-yellow rounded-xl">
                                <i data-lucide="clipboard-check"></i>
                            </div>
                            <span class="text-xs font-bold text-yellow-600 bg-yellow-50 px-2 py-1 rounded-full">3 hoy</span>
                        </div>
                        <p class="text-sm text-gray-500 font-medium">Inspecciones Realizadas</p>
                        <h3 class="text-2xl font-bold mt-1">24 / 30</h3>
                    </div>
                </div>

                <!-- Main Section Grid -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <!-- Table: Upcoming Inspections -->
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                        <div class="flex justify-between items-center mb-6">
                            <h3 class="font-bold text-lg">Inspecciones Programadas</h3>
                            <button class="text-prolub-purple text-sm font-semibold hover:underline">Ver todas</button>
                        </div>
                        <div class="space-y-4">
                            <div class="flex items-center p-4 bg-gray-50 rounded-xl">
                                <div class="w-12 h-12 bg-white rounded-lg flex items-center justify-center shadow-sm mr-4">
                                    <span class="text-prolub-purple font-bold">15</span>
                                </div>
                                <div class="flex-1">
                                    <h4 class="text-sm font-bold">Inspección Locativa - Planta A</h4>
                                    <p class="text-xs text-gray-500">Pendiente de ejecución</p>
                                </div>
                                <span class="px-3 py-1 bg-yellow-100 text-yellow-700 text-xs font-bold rounded-full text-prolub-yellow">Urgente</span>
                            </div>
                            <div class="flex items-center p-4 bg-gray-50 rounded-xl">
                                <div class="w-12 h-12 bg-white rounded-lg flex items-center justify-center shadow-sm mr-4">
                                    <span class="text-prolub-purple font-bold">18</span>
                                </div>
                                <div class="flex-1">
                                    <h4 class="text-sm font-bold">Revisión de Extintores</h4>
                                    <p class="text-xs text-gray-500">Programada mensualmente</p>
                                </div>
                                <span class="px-3 py-1 bg-green-100 text-green-700 text-xs font-bold rounded-full">Al día</span>
                            </div>
                        </div>
                    </div>

                    <!-- Risk Chart Placeholder -->
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 flex flex-col justify-center items-center">
                        <h3 class="font-bold text-lg w-full mb-6 text-left">Matriz de Riesgo Crítico</h3>
                        <div class="w-48 h-48 rounded-full border-[15px] border-prolub-light flex items-center justify-center relative">
                            <div class="absolute inset-0 border-[15px] border-prolub-purple rounded-full" style="clip-path: polygon(0 0, 100% 0, 100% 60%, 0 60%);"></div>
                            <div class="text-center">
                                <span class="text-3xl font-bold">60%</span>
                                <p class="text-[10px] text-gray-500 uppercase font-bold tracking-wider">Mitigado</p>
                            </div>
                        </div>
                        <div class="mt-6 grid grid-cols-2 gap-4 w-full">
                            <div class="flex items-center text-xs">
                                <div class="w-3 h-3 bg-prolub-purple rounded-full mr-2"></div> Riesgos Altos
                            </div>
                            <div class="flex items-center text-xs">
                                <div class="w-3 h-3 bg-prolub-light rounded-full mr-2"></div> Riesgos Medios
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        // Inicializar Iconos
        lucide.createIcons();

        // Función para cambiar pantallas (Simulación)
        function showDashboard() {
            document.getElementById('login-screen').classList.add('hidden');
            document.getElementById('dashboard').classList.remove('hidden');
            // Re-inicializar iconos porque estaban ocultos
            lucide.createIcons();
        }
    </script>
</body>
</html>
